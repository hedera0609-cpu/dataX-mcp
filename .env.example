# =====================================
# DataX MCP サーバー 環境変数設定例
# このファイルをコピーして .env を作成すること
# .env は絶対にGitにコミットしないこと
# =====================================

# ─── MCP サーバー設定 ────────────────────────────────────────
# 各ユーザーのニックネーム（英小文字・数字・ハイフンのみ）
DATAX_NICKNAME=yourname

# ─── AWS 基本設定 ────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ─── インフラリソース（CDK デプロイ後に設定する）────────────
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com
ECS_CLUSTER=datax-cluster
DYNAMODB_TABLE=datax-apps
S3_BUCKET=datax-app-sources-123456789012-ap-northeast-2

# ALB 設定
ALB_LISTENER_ARN=arn:aws:elasticloadbalancing:ap-northeast-2:123456789012:listener/app/datax-alb/xxx/xxx
ALB_DNS_NAME=datax-alb-123456789.ap-northeast-2.elb.amazonaws.com

# VPC 設定
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
ECS_SUBNETS=subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy
ECS_SECURITY_GROUP=sg-xxxxxxxxxxxxxxxxx

# IAM ロール
TASK_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/datax-task-execution-role
TASK_ROLE_ARN=arn:aws:iam::123456789012:role/datax-task-role

# ─── Phase 2: ドメイン設定（オプション）──────────────────────
# 設定するとサブドメインURLが自動生成される
# 例: https://datax-park--myapp.sandbox.yourcompany.com
DATAX_DOMAIN=sandbox.yourcompany.com
ACM_CERTIFICATE_ARN=arn:aws:acm:ap-northeast-2:123456789012:certificate/xxx

# ─── Phase 2: Git サーバー設定（オプション）──────────────────
GIT_SERVER_URL=http://git.internal/datax

# ─── CDK デプロイ時のみ必要 ──────────────────────────────────
CDK_DEFAULT_ACCOUNT=123456789012

# ─── IP アクセス制限（CDK デプロイ時に必要） ──────────────────
# CIDR形式で記入すること（例: 203.0.113.1/32）
ALLOWED_OFFICE_IP=xxx.xxx.xxx.xxx/32
ALLOWED_VPN_IP=xxx.xxx.xxx.xxx/32
